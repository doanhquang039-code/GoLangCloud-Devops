@baseUrl = http://localhost:8080

### Health check
GET {{baseUrl}}/healthz

### Readiness check
GET {{baseUrl}}/readyz

### Prometheus metrics
GET {{baseUrl}}/metrics

### Create employee
POST {{baseUrl}}/api/v1/employees
Content-Type: application/json

{
  "name": "Nguyen Van A",
  "email": "a@example.com",
  "department": "Engineering",
  "title": "Backend Engineer"
}

### List employees
GET {{baseUrl}}/api/v1/employees

### Search platform SRE employees
GET {{baseUrl}}/api/v1/employees?q=nguyen&department=Platform%20Engineering&title=SRE

### Update employee
PUT {{baseUrl}}/api/v1/employees/replace-with-created-employee-id
Content-Type: application/json

{
  "name": "Nguyen Van A",
  "email": "a@example.com",
  "department": "Platform Engineering",
  "title": "Senior Backend Engineer"
}

### Delete employee
DELETE {{baseUrl}}/api/v1/employees/replace-with-created-employee-id

### Create application
POST {{baseUrl}}/api/v1/applications
Content-Type: application/json

{
  "name": "payroll-api",
  "repository": "github.com/company/payroll-api",
  "runtime": "go1.22",
  "owner_team": "platform",
  "criticality": "high",
  "port": 8080,
  "replicas": 3,
  "health_endpoint": "/healthz",
  "environment": {
    "LOG_LEVEL": "info",
    "FEATURE_FLAGS": "payroll-v2"
  },
  "tags": ["go", "payroll", "backend"]
}

### List applications
GET {{baseUrl}}/api/v1/applications

### List platform Go backend applications
GET {{baseUrl}}/api/v1/applications?owner_team=platform&criticality=high&runtime=go1.22&tag=backend

### Search payroll applications
GET {{baseUrl}}/api/v1/applications?q=payroll&owner_team=platform

### Update application
PUT {{baseUrl}}/api/v1/applications/replace-with-created-application-id
Content-Type: application/json

{
  "name": "payroll-api",
  "repository": "github.com/company/payroll-api",
  "runtime": "go1.22",
  "owner_team": "platform",
  "criticality": "critical",
  "port": 8080,
  "replicas": 4,
  "health_endpoint": "/readyz",
  "environment": {
    "LOG_LEVEL": "debug",
    "FEATURE_FLAGS": "payroll-v2"
  },
  "tags": ["go", "payroll", "backend", "tier-1"]
}

### Delete application
DELETE {{baseUrl}}/api/v1/applications/replace-with-created-application-id

### Create cluster
POST {{baseUrl}}/api/v1/clusters
Content-Type: application/json

{
  "name": "eks-staging-ap-southeast-1",
  "provider": "aws",
  "region": "ap-southeast-1",
  "endpoint": "https://staging.example.eks.amazonaws.com",
  "version": "1.30",
  "status": "ready"
}

### List clusters
GET {{baseUrl}}/api/v1/clusters

### List ready AWS clusters in Singapore
GET {{baseUrl}}/api/v1/clusters?provider=aws&region=ap-southeast-1&status=ready

### Search clusters by name, endpoint, or version
GET {{baseUrl}}/api/v1/clusters?q=staging&provider=aws&status=ready

### Update cluster
PUT {{baseUrl}}/api/v1/clusters/replace-with-created-cluster-id
Content-Type: application/json

{
  "name": "eks-staging-ap-southeast-1",
  "provider": "aws",
  "region": "ap-southeast-1",
  "endpoint": "https://staging.example.eks.amazonaws.com",
  "version": "1.31",
  "status": "maintenance"
}

### Mark cluster degraded
PATCH {{baseUrl}}/api/v1/clusters/replace-with-created-cluster-id
Content-Type: application/json

{
  "status": "degraded"
}

### Delete cluster
DELETE {{baseUrl}}/api/v1/clusters/replace-with-created-cluster-id

### Create cloud account
POST {{baseUrl}}/api/v1/cloud-accounts
Content-Type: application/json

{
  "name": "hr-prod-aws",
  "provider": "aws",
  "account_id": "123456789012",
  "region": "ap-southeast-1",
  "owner_team": "platform",
  "environment": "production",
  "monthly_cost_usd": 18420.75,
  "budget_usd": 25000,
  "compliance_score": 91,
  "backup_status": "protected",
  "open_security_findings": 3,
  "tags": ["hr", "prod", "aws"]
}

### List cloud accounts
GET {{baseUrl}}/api/v1/cloud-accounts

### Filter production AWS cloud accounts with protected backups
GET {{baseUrl}}/api/v1/cloud-accounts?provider=aws&environment=production&backup_status=protected&tag=prod

### Cloud account summary
GET {{baseUrl}}/api/v1/cloud/summary

### Cloud policy violations
GET {{baseUrl}}/api/v1/cloud/policy-violations?provider=aws&environment=production

### Cloud remediation plan
GET {{baseUrl}}/api/v1/cloud/remediation-plan?owner_team=platform

### Update cloud account posture
PATCH {{baseUrl}}/api/v1/cloud-accounts/replace-with-created-cloud-account-id
Content-Type: application/json

{
  "status": "restricted",
  "backup_status": "partial"
}

### Delete cloud account
DELETE {{baseUrl}}/api/v1/cloud-accounts/replace-with-created-cloud-account-id

### Create environment
POST {{baseUrl}}/api/v1/environments
Content-Type: application/json

{
  "name": "payroll-staging",
  "type": "staging",
  "application_id": "replace-with-created-application-id",
  "cluster_id": "replace-with-created-cluster-id",
  "namespace": "hr-staging",
  "status": "active",
  "variables": {
    "LOG_LEVEL": "debug",
    "FEATURE_FLAGS": "payroll-v2"
  }
}

### List environments
GET {{baseUrl}}/api/v1/environments

### List active staging environments
GET {{baseUrl}}/api/v1/environments?type=staging&status=active

### Search environments by name, namespace, or variable
GET {{baseUrl}}/api/v1/environments?q=payroll-v2&type=staging&status=active

### Update environment
PUT {{baseUrl}}/api/v1/environments/replace-with-created-environment-id
Content-Type: application/json

{
  "name": "payroll-staging",
  "type": "staging",
  "application_id": "replace-with-created-application-id",
  "cluster_id": "replace-with-created-cluster-id",
  "namespace": "hr-staging",
  "status": "active",
  "variables": {
    "LOG_LEVEL": "info",
    "FEATURE_FLAGS": "payroll-v2"
  }
}

### Delete environment
DELETE {{baseUrl}}/api/v1/environments/replace-with-created-environment-id

### Create deployment
POST {{baseUrl}}/api/v1/deployments
Content-Type: application/json

{
  "tenant_id": "tenant-hr",
  "application_id": "replace-with-created-application-id",
  "cluster_id": "replace-with-created-cluster-id",
  "namespace": "hr-staging",
  "environment": "staging",
  "version": "v1.3.0",
  "strategy": "canary",
  "requested_by": "devops@company.com"
}

### List deployments
GET {{baseUrl}}/api/v1/deployments

### List running staging deployments
GET {{baseUrl}}/api/v1/deployments?environment=staging&status=running

### Search deployments by version, strategy, or requester
GET {{baseUrl}}/api/v1/deployments?q=canary&environment=staging&status=running

### Update deployment
PUT {{baseUrl}}/api/v1/deployments/replace-with-created-deployment-id
Content-Type: application/json

{
  "application_id": "replace-with-created-application-id",
  "cluster_id": "replace-with-created-cluster-id",
  "namespace": "hr-staging",
  "environment": "staging",
  "version": "v1.3.1",
  "strategy": "blue-green",
  "requested_by": "devops@company.com"
}

### Mark deployment as succeeded
PATCH {{baseUrl}}/api/v1/deployments/replace-with-created-deployment-id
Content-Type: application/json

{
  "status": "succeeded"
}

### Delete deployment
DELETE {{baseUrl}}/api/v1/deployments/replace-with-created-deployment-id

### Create pipeline run
POST {{baseUrl}}/api/v1/pipelines
Content-Type: application/json

{
  "application_id": "replace-with-created-application-id",
  "branch": "main",
  "commit_sha": "4f9a2c9",
  "triggered_by": "devops@company.com",
  "stages": ["build", "unit-test", "security-scan", "containerize"]
}

### List pipeline runs
GET {{baseUrl}}/api/v1/pipelines

### List running main branch pipelines
GET {{baseUrl}}/api/v1/pipelines?branch=main&status=running

### Search pipeline runs by commit, actor, or stage
GET {{baseUrl}}/api/v1/pipelines?q=security&status=running

### Mark pipeline as succeeded
PATCH {{baseUrl}}/api/v1/pipelines/replace-with-created-pipeline-id
Content-Type: application/json

{
  "status": "succeeded"
}

### Mark pipeline build stage as succeeded
PATCH {{baseUrl}}/api/v1/pipelines/replace-with-created-pipeline-id/stages/build
Content-Type: application/json

{
  "status": "succeeded"
}

### Delete pipeline run
DELETE {{baseUrl}}/api/v1/pipelines/replace-with-created-pipeline-id

### Create microservice
POST {{baseUrl}}/api/v1/microservices
Content-Type: application/json

{
  "application_id": "replace-with-created-application-id",
  "name": "payroll-api",
  "owner_team": "platform",
  "protocol": "http",
  "endpoint": "http://payroll-api:8080",
  "status": "active",
  "cloud_provider": "aws",
  "region": "ap-southeast-1",
  "cluster_id": "replace-with-created-cluster-id",
  "namespace": "hr-staging",
  "environment": "staging",
  "runtime": "go1.22",
  "image": "ghcr.io/company/payroll-api:v1.3.0",
  "version": "v1.3.0",
  "replicas": 3,
  "cpu_request": "250m",
  "memory_request": "512Mi",
  "health_path": "/readyz",
  "slo_target": 99.95,
  "error_budget_remaining": 82.5,
  "dependencies": ["mongodb", "audit-events"],
  "config": {
    "TIMEOUT_SECONDS": "5"
  },
  "tags": ["backend", "payroll"]
}

### List active HTTP microservices
GET {{baseUrl}}/api/v1/microservices?tenant_id=tenant-hr&protocol=http&status=active&cloud_provider=aws&environment=staging&tag=backend&min_replicas=2&limit=100&sort=id&after_id=svc-payroll-api

### Search payroll microservices
GET {{baseUrl}}/api/v1/microservices?tenant_id=tenant-hr&q=payroll&owner_team=platform&status=active&region=ap-southeast-1&namespace=hr-staging

### Update microservice
PUT {{baseUrl}}/api/v1/microservices/replace-with-created-microservice-id
Content-Type: application/json

{
  "tenant_id": "tenant-hr",
  "application_id": "replace-with-created-application-id",
  "name": "payroll-worker",
  "owner_team": "platform",
  "protocol": "worker",
  "endpoint": "queue://payroll-jobs",
  "status": "active",
  "cloud_provider": "aws",
  "region": "ap-southeast-1",
  "cluster_id": "replace-with-created-cluster-id",
  "namespace": "hr-staging",
  "environment": "staging",
  "runtime": "go1.22",
  "image": "ghcr.io/company/payroll-worker:v1.3.1",
  "version": "v1.3.1",
  "replicas": 4,
  "cpu_request": "500m",
  "memory_request": "768Mi",
  "health_path": "/healthz",
  "slo_target": 99.9,
  "error_budget_remaining": 75,
  "dependencies": ["mongodb", "payroll-events"],
  "config": {
    "CONCURRENCY": "4"
  },
  "tags": ["backend", "payroll", "worker"]
}

### Mark microservice as degraded
PATCH {{baseUrl}}/api/v1/microservices/replace-with-created-microservice-id
Content-Type: application/json

{
  "status": "degraded"
}

### Delete microservice
DELETE {{baseUrl}}/api/v1/microservices/replace-with-created-microservice-id

### Create incident
POST {{baseUrl}}/api/v1/incidents
Content-Type: application/json

{
  "title": "Payroll API error rate elevated",
  "summary": "5xx responses are above the platform threshold after the latest rollout.",
  "severity": "sev2",
  "status": "investigating",
  "application_id": "replace-with-created-application-id",
  "cluster_id": "replace-with-created-cluster-id",
  "deployment_id": "replace-with-created-deployment-id",
  "owner_team": "platform"
}

### List incidents
GET {{baseUrl}}/api/v1/incidents

### List active platform incidents
GET {{baseUrl}}/api/v1/incidents?owner_team=platform&status=investigating

### Search incidents by title, summary, service, or owner
GET {{baseUrl}}/api/v1/incidents?q=canary&severity=sev2&status=investigating&owner_team=platform

### Resolve incident
PATCH {{baseUrl}}/api/v1/incidents/replace-with-created-incident-id
Content-Type: application/json

{
  "status": "resolved"
}

### Delete incident
DELETE {{baseUrl}}/api/v1/incidents/replace-with-created-incident-id

